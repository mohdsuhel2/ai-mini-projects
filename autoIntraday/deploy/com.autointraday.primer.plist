<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.autointraday.primer</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/mohdsuhel/ai-mini-projects/autoIntraday/.venv/bin/python</string>
        <string>/Users/mohdsuhel/ai-mini-projects/autoIntraday/prime_claude.py</string>
    </array>

    <!-- Fires 2 hours before the first trading cycle on weekdays (07:45 for a 09:45 start) so
         the Claude subscription's rolling ~5h usage window starts early and resets mid-session.
         schedule_manager keeps this in sync with the trading schedule's first-cycle time.
         Gated by the DB primer_enabled flag (dashboard toggle); a disabled run is a clean no-op,
         so this stays loaded and the UI toggle alone turns priming on/off. No creds needed —
         the claude CLI reads the subscription token from the login Keychain. -->
    <key>WorkingDirectory</key>
    <string>/Users/mohdsuhel/ai-mini-projects/autoIntraday</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>AUTOINTRADAY_CONFIG</key>
        <string>/Users/mohdsuhel/ai-mini-projects/autoIntraday/config.yaml</string>
        <key>CLAUDE_BIN</key>
        <string>/Users/mohdsuhel/.local/bin/claude</string>
        <key>HOME</key>
        <string>/Users/mohdsuhel</string>
        <key>PATH</key>
        <string>/Users/mohdsuhel/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>7</integer><key>Minute</key><integer>45</integer></dict>
        <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>7</integer><key>Minute</key><integer>45</integer></dict>
        <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>7</integer><key>Minute</key><integer>45</integer></dict>
        <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>7</integer><key>Minute</key><integer>45</integer></dict>
        <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>7</integer><key>Minute</key><integer>45</integer></dict>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/mohdsuhel/.autointraday/primer.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mohdsuhel/.autointraday/primer.err.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
